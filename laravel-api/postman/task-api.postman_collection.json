{
  "info": {
    "name": "Laravel Task API Teaching Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "{{base_url}}/health" }
    },
    {
      "name": "Get Tasks",
      "request": { "method": "GET", "url": "{{base_url}}/tasks" }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Learn Vue.js\",\n  \"description\": \"Build frontend UI\",\n  \"priority\": \"high\"\n}"
        },
        "url": "{{base_url}}/tasks"
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" },
        "url": "{{base_url}}/tasks/1"
      }
    },
    {
      "name": "Delete Task",
      "request": { "method": "DELETE", "url": "{{base_url}}/tasks/1" }
    }
  ]
}
